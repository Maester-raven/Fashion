  "record_schema": {
    "required_top_level_fields": [
      "schema_version",
      "dataset",
      "image_id",
      "image_path",
      "width",
      "height",
      "instances"
    ],
    "instance_fields": {
      "instance_id": "string, unique inside image",
      "category": "one of category_taxonomy.categories",
      "category_id": "integer, optional stable id",
      "bbox": "[x1, y1, x2, y2] in image coordinates",
      "segmentation": "COCO polygon/RLE, binary mask path, or null",
      "segmentation_format": "one of source_types.segmentation_format",
      "area": "mask area in pixels",
      "instance_source": "one of source_types.instance_source",
      "confidence": "float in [0, 1]",
      "attributes": "list of attribute records"
    },
    "attribute_fields": {
      "attribute_id": "stable attribute id",
      "attribute_name": "original FashionAI attribute name when available",
      "attribute_value": "original or predicted attribute value",
      "target_part": "one of target_part_taxonomy keys",
      "scope": "global or local",
      "attribute_source": "one of source_types.attribute_source",
      "confidence": "1.0 for FashionAI_original, model probability for pseudo labels",
      "region": "region record"
    },
    "region_fields": {
      "region_id": "string, optional",
      "target_part": "one of target_part_taxonomy keys",
      "bbox": "[x1, y1, x2, y2] in image coordinates, null if missing",
      "segmentation": "COCO polygon/RLE, binary mask path, or null",
      "segmentation_format": "one of source_types.segmentation_format",
      "area": "region mask area in pixels, optional",
      "region_source": "one of source_types.region_source",
      "confidence": "float in [0, 1]",
      "is_derived_from_instance": "boolean"
    }
  },
  "quality_rules": {
    "fashionai_original_attribute_confidence": 1.0,
    "dinov2_pseudo_attribute_min_confidence": 0.65,
    "instance_min_area_ratio": 0.002,
    "local_region_min_area_ratio": 0.0005,
    "local_region_max_instance_area_ratio": 0.6,
    "region_must_intersect_instance": true,
    "region_prefer_inside_instance": true,
    "invalid_attribute_value": "Invisible",
    "ignore_invisible_attribute_for_positive_training": true
  },
  "language_query_schema": {
    "description": "Training item format for language-guided local region grounding.",
    "fields": {
      "query_id": "string",
      "image_id": "string",
      "instance_id": "string",
      "query": "natural language part or attribute query",
      "target_part": "one of target_part_taxonomy keys",
      "bbox": "[x1, y1, x2, y2]",
      "segmentation": "target region mask",
      "segmentation_format": "COCO polygon/RLE, binary mask path, or none",
      "source_attribute_id": "optional linked attribute id",
      "region_source": "one of source_types.region_source",
      "confidence": "float in [0, 1]"
    }
  },
  "region_generation_policy": {
    "stage_order": [
      "use_instance_mask_for_global_attributes",
      "derive_geometric_part_region_for_supported_local_parts",
      "clip_part_region_to_instance_mask_when_mask_exists",
      "fall_back_to_language_grounding_sam_for_object_like_parts",
      "mark_region_source_missing_when_no_reliable_region_exists"
    ],
    "geometric_parts": [
      "collar",
      "lapel",
      "neck",
      "neckline",
      "sleeve",
      "cuff",
      "hem",
      "waist",
      "shoulder"
    ],
    "language_grounding_parts": [
      "pocket",
      "pattern",
      "decoration"
    ],
    "quality_thresholds": {
      "min_region_area_ratio_of_image": 0.0005,
      "min_region_area_ratio_of_instance": 0.015,
      "max_region_area_ratio_of_instance": 0.75,
      "require_region_intersects_instance": true,
      "prefer_region_inside_instance": true
    },
    "notes": "FashionAI has original attribute labels but no instance/part masks. Local regions are generated labels and must keep region_source/confidence."
  },
